# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/qa_platform

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRE=30d

# Email Configuration (Gmail example)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=QA Platform <noreply@qaplatform.com>

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Automation Service
AUTOMATION_SERVICE_URL=http://localhost:5001

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
```

### `.gitignore`
```
node_modules/
.env
*.log
.DS_Store
uploads/
*.pyc
__pycache__/
.vscode/
.idea/